---
import { Image } from 'astro:assets';
import Base from '@layouts/Base.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import ConsentBanner from '@components/layout/ConsentBanner.astro';
import Hero from '@components/sections/Hero.astro';
import NumberedPrinciples from '@components/sections/NumberedPrinciples.astro';
import DifferenceMatrix from '@components/sections/DifferenceMatrix.astro';
import CoreValues from '@components/sections/CoreValues.astro';
import SeamHatch from '@components/ui/SeamHatch.astro';
import CTABand from '@components/sections/CTABand.astro';
import krakenNavy from '@assets/brand/kraken-navy.png';
import { sportsOrganizationSchema, jsonLd } from '@lib/schemas';
import { mission, vision, openWaterCredentials } from '@data/approach';

const orgSchema = sportsOrganizationSchema();
---
<Base
  title="Our Approach | C26 Aquatics"
  description="How C26 Aquatics develops swimmers — purposeful, periodized training, long-term athlete development, a single home pool, and the Midwest's premier open water program in the Kansas City metro."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(orgSchema)}></script>
  </Fragment>

  <Header />
  <main>
    <Hero
      variant="page"
      eyebrow="Our Approach"
      title="Our <span class='hero-accent'>approach</span>"
      subtitle="Great swimmers are developed through purpose, patience, and consistency — not endless laps and accumulated yardage."
    />

    <!-- The C26 method — four numbered principles -->
    <NumberedPrinciples />

    <SeamHatch />
    <section class="pullquote" aria-label="Our training philosophy">
      <div class="container">
        <p class="pullquote__text">Train with purpose. Develop for the long term. <span class="pullquote__accent">Peak when it matters most.</span> Love the process.</p>
      </div>
    </section>

    <!-- Difference Matrix -->
    <DifferenceMatrix />

    <!-- Mission & Vision -->
    <section class="statements" aria-labelledby="mission-title">
      <div class="container">
        <div class="statement">
          <p class="statement__eyebrow">Our mission</p>
          <p id="mission-title" class="statement__text">{mission}</p>
        </div>
        <div class="statement">
          <p class="statement__eyebrow">Our vision</p>
          <p class="statement__text statement__text--sm">{vision}</p>
        </div>
      </div>
    </section>

    <!-- Core Values -->
    <CoreValues />

    <!-- Our home -->
    <section id="our-home" class="feature feature--alt" aria-labelledby="home-title">
      <div class="container feature__inner">
        <div class="feature__media" role="img" aria-label="Facility photo — the C26 Hub pool">
          <Image
            src={krakenNavy}
            alt=""
            class="feature__placeholder-kraken"
            widths={[320, 480]}
            sizes="(max-width: 860px) 90vw, 45vw"
            loading="lazy"
          />
          <span class="feature__placeholder-label">Facility photo — C26 Hub pool</span>
        </div>
        <div class="feature__copy">
          <p class="feature__eyebrow">Our home</p>
          <h2 id="home-title" class="feature__heading">One facility. Everything your swimmer needs.</h2>
          <p class="feature__text">Unlike clubs that rent and rotate pools, we own our home at the C26 Hub inside AdventHealth SportsPark at Bluhawk — a dedicated three-lane lap pool with its own entrance and parking.</p>
          <p class="feature__text">Connected to a 10,000-square-foot performance facility for dryland, strength, and recovery — infrared saunas, cold tubs, and compression for swimmers 13 and older.</p>
        </div>
      </div>
    </section>

    <!-- Beyond the pool -->
    <section class="feature feature--rule" aria-labelledby="beyond-title">
      <div class="container feature__inner">
        <div class="feature__copy">
          <p class="feature__eyebrow">Beyond the pool</p>
          <h2 id="beyond-title" class="feature__heading">The Midwest's premier open water swimming program</h2>
          <p class="feature__text">We believe swimming should create opportunities that extend far beyond the lane lines. Open water is one of the fastest-growing disciplines in the sport — and one of the areas that truly separates C26 Aquatics.</p>
          <p class="feature__text">Coach Robbie is widely recognized as one of the Midwest's leading open water coaches, with a decade guiding hundreds of swimmers at every level of the sport.</p>

          <ul class="chips" aria-label="Coach Robbie's open water credentials">
            {openWaterCredentials.map((c) => (
              <li class="chip">{c}</li>
            ))}
          </ul>

          <a class="feature__link" href="/our-story">
            <span class="feature__link-arrow" aria-hidden="true">▸</span>
            Read the full story
          </a>
        </div>
        <div class="feature__media" role="img" aria-label="Open water action photo">
          <Image
            src={krakenNavy}
            alt=""
            class="feature__placeholder-kraken"
            widths={[320, 480]}
            sizes="(max-width: 860px) 90vw, 45vw"
            loading="lazy"
          />
          <span class="feature__placeholder-label">Open water action photo</span>
        </div>
      </div>
    </section>

    <SeamHatch />
    <CTABand
      title="Ready to <span class='hero-accent accent'>join the team</span>?"
      watermark="right"
      primaryCta={{ label: 'Join the Team', href: '/team' }}
      secondaryCta={{ label: 'Read our story', href: '/our-story' }}
    />
  </main>
  <Footer />
  <ConsentBanner />
</Base>

<style>
  /* Navy pull-quote */
  .pullquote {
    background: var(--navy-900);
    color: var(--text-on-dark);
    padding: var(--section-y) 0;
  }
  .pullquote__text {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(24px, 3.4vw, 40px);
    line-height: 1.12;
    letter-spacing: var(--ls-tight);
    color: var(--white);
    text-wrap: balance;
  }
  .pullquote__accent {
    color: var(--teal-400);
  }

  /* Mission / Vision statements */
  .statements {
    background: var(--surface);
    padding: var(--section-y) 0;
  }
  .statements .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 6vw, 72px);
    align-items: start;
  }
  .statement__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--magenta-500);
    margin: 0 0 var(--space-3);
  }
  .statement__text {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: clamp(20px, 2.4vw, 27px);
    line-height: 1.25;
    color: var(--navy-700);
    margin: 0;
    text-wrap: balance;
  }
  .statement__text--sm {
    font-family: var(--font-body);
    font-weight: var(--fw-regular, 400);
    text-transform: none;
    font-size: 16px;
    line-height: 1.65;
    color: var(--text-body);
  }

  /* Feature bands (Our home / Beyond the pool) */
  .feature {
    background: var(--surface);
    padding: var(--section-y) 0;
  }
  .feature--alt {
    background: var(--surface-alt);
  }
  .feature__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(32px, 5vw, 48px);
  }
  .feature--rule .feature__inner {
    border-left: 5px solid var(--teal-500);
    padding-left: clamp(var(--space-6), 4vw, var(--space-10, 40px));
  }

  .feature__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-600);
    margin: 0 0 var(--space-2);
  }
  .feature__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(26px, 3vw, 34px);
    line-height: 1.04;
    letter-spacing: var(--ls-tight);
    color: var(--navy-700);
    margin: 0 0 var(--space-4);
  }
  .feature__text {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--text-body);
    margin: 0 0 var(--space-4);
  }
  .feature__text:last-child {
    margin-bottom: 0;
  }

  /* Credential chips */
  .chips {
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .chip {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 12px;
    color: var(--teal-700);
    background: var(--surface);
    border: 1px solid var(--teal-400);
    border-radius: var(--r-pill);
    padding: 8px 18px;
  }

  /* Read the full story */
  .feature__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-6);
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 14px;
    color: var(--teal-700);
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition:
      border-color var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }
  .feature__link-arrow {
    color: var(--orange-500);
    font-size: 12px;
    line-height: 1;
  }
  .feature__link:hover {
    color: var(--navy-700);
    border-bottom-color: var(--teal-500);
  }

  .feature__media {
    position: relative;
    height: 320px;
    border-radius: var(--r-lg);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--mist) 0%, var(--surface-inset) 100%);
    border: 1px solid var(--border);
  }
  .feature__placeholder-kraken {
    width: 42%;
    height: auto;
    opacity: 0.12;
  }
  .feature__placeholder-label {
    position: absolute;
    bottom: var(--space-4);
    left: 0;
    right: 0;
    text-align: center;
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 12px;
    color: var(--text-muted);
  }

  @media (max-width: 860px) {
    .statements .container { grid-template-columns: 1fr; }
    .feature__inner { grid-template-columns: 1fr; gap: var(--space-8); }
    /* Keep image above copy on both bands when stacked */
    .feature--rule .feature__copy { order: -1; }
  }
</style>

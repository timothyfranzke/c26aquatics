---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '@layouts/Base.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import ConsentBanner from '@components/layout/ConsentBanner.astro';
import Hero from '@components/sections/Hero.astro';
import CoachesGrid from '@components/sections/CoachesGrid.astro';
import CTABand from '@components/sections/CTABand.astro';
import { site } from '@data/site';
import {
  sportsOrganizationSchema,
  coachesListSchema,
  jsonLd,
} from '@lib/schemas';

type CoachEntry = CollectionEntry<'coaches'>;

const orgSchema = sportsOrganizationSchema();

const coachEntries = (await getCollection('coaches')).sort(
  (a: CoachEntry, b: CoachEntry) => a.data.order - b.data.order,
);

const coachesForSchema = coachEntries.map((entry: CoachEntry) => ({
  slug: entry.slug,
  name: entry.data.name,
  role: entry.data.role,
  headshot: entry.data.headshot,
  credentials: entry.data.credentials,
}));

const coachListSchema = coachesListSchema(coachesForSchema);
---
<Base
  title="Our Coaches | C26 Aquatics"
  description="Meet the C26 Aquatics coaching staff — USA Swimming–registered, SafeSport-certified coaches developing competitive and beginner swimmers across the KC metro."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(orgSchema)}></script>
    <script type="application/ld+json" set:html={jsonLd(coachListSchema)}></script>
  </Fragment>

  <Header />
  <main>
    <Hero
      variant="page"
      eyebrow="Coaches"
      title="Meet the <span class='hero-accent'>coaching staff</span>"
      subtitle="USA Swimming–registered, SafeSport-certified, KC-rooted — every coach here is a professional, not a part-timer."
    />

    <CoachesGrid
      tone="light"
      eyebrow="The staff"
      heading="The C26 coaching staff"
      subtitle="Each coach is registered with USA Swimming and current on SafeSport — see bios, credentials, and how to reach the right coach for your swimmer."
    />

    <CTABand
      title="Train with the <span class='hero-accent accent'>best</span>"
      primaryCta={{ label: 'Start tryouts', href: site.booking.team, external: true }}
      secondaryCta={{ label: 'Book a lesson', href: site.booking.lessons, external: true }}
    />
  </main>
  <Footer />
  <ConsentBanner />
</Base>

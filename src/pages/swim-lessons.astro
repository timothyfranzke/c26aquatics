---
import { getCollection, type CollectionEntry } from 'astro:content';
import { micromark } from 'micromark';
import Base from '@layouts/Base.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import ConsentBanner from '@components/layout/ConsentBanner.astro';
import Hero from '@components/sections/Hero.astro';
import FAQAccordion from '@components/sections/FAQAccordion.astro';
import CTABand from '@components/sections/CTABand.astro';
import TrackTabs from '@components/widgets/TrackTabs.astro';
import StatBlock from '@components/ui/StatBlock.astro';
import { site } from '@data/site';
import {
  sportsOrganizationSchema,
  lessonsServiceSchema,
  jsonLd,
} from '@lib/schemas';

type LessonEntry = CollectionEntry<'lesson-tracks'>;

const orgSchema = sportsOrganizationSchema();
const serviceSchema = lessonsServiceSchema();

const lessons = (await getCollection('lesson-tracks')).sort(
  (a: LessonEntry, b: LessonEntry) => a.data.order - b.data.order,
);

const formatLabel: Record<LessonEntry['data']['format'], string> = {
  group: 'Group',
  'semi-private': 'Semi-private',
  private: 'Private',
};

const classSizeFor = (format: LessonEntry['data']['format']): string => {
  switch (format) {
    case 'group':
      return 'Up to 6 swimmers';
    case 'semi-private':
      return '2–3 swimmers';
    case 'private':
      return '1 swimmer';
  }
};

const tracks = lessons.map((entry: LessonEntry) => ({
  slug: entry.slug,
  name: entry.data.name,
  eyebrowText: entry.data.ageRange,
  bodyHtml: micromark(entry.body),
  meta: [
    { label: 'Ages', value: entry.data.ageRange },
    { label: 'Format', value: formatLabel[entry.data.format] },
    { label: 'Class size', value: classSizeFor(entry.data.format) },
  ],
}));
---
<Base
  title="Swim Lessons in Kansas City | C26 Aquatics"
  description="Swim lessons from infant through adult in the Kansas City metro. Group, semi-private, and private formats taught by USA Swimming–certified coaches."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(orgSchema)}></script>
    <script type="application/ld+json" set:html={jsonLd(serviceSchema)}></script>
  </Fragment>

  <Header />
  <main>
    <Hero
      variant="page"
      eyebrow="Swim lessons"
      title="Swim lessons for <span class='hero-accent'>every age</span>"
      subtitle="From parent-and-tot through adult — group, semi-private, and private formats in our warm indoor pool."
      primaryCta={{ label: 'Book a lesson', href: site.booking.lessons, external: true }}
    />

    <TrackTabs
      id="lesson-tabs"
      eyebrow="Lesson tracks"
      heading="Find your track"
      subtitle="Five tracks based on age and format — every swimmer placed by a free water evaluation."
      tracks={tracks}
    />

    <section class="philosophy" aria-labelledby="lessons-philosophy-title">
      <div class="container philosophy__inner">
        <header class="philosophy__head">
          <p class="philosophy__eyebrow">Why C26 lessons</p>
          <h2 id="lessons-philosophy-title" class="philosophy__heading">
            Small classes. Year-round pool. Real coaches.
          </h2>
          <p class="philosophy__lede">
            Every C26 lesson is taught by a SafeSport-certified coach in a heated indoor
            pool. We cap class sizes for actual attention, and run all year so progress
            never stalls.
          </p>
        </header>
        <div class="philosophy__stats">
          <StatBlock value="5" label="Lesson tracks" accent="orange" tone="light" align="left" />
          <StatBlock value="≤6" label="Swimmers per group class" accent="teal" tone="light" align="left" />
          <StatBlock value="365" label="Days a year, indoor pool" accent="navy" tone="light" align="left" />
        </div>
      </div>
    </section>

    <FAQAccordion surface="swim-lessons" heading="Lesson FAQs" />

    <CTABand
      title="Ready to <span class='hero-accent accent'>book your first lesson?</span>"
      primaryCta={{ label: 'Book now', href: site.booking.lessons, external: true }}
    />
  </main>
  <Footer />
  <ConsentBanner />
</Base>

<style>
  .philosophy {
    background: var(--surface-alt);
    padding: var(--section-y) 0;
  }
  .philosophy__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-12);
    align-items: center;
  }
  .philosophy__head {
    max-width: 520px;
  }
  .philosophy__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-600);
    margin: 0 0 var(--space-2);
  }
  .philosophy__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(26px, 3.4vw, 38px);
    color: var(--navy-700);
    margin: 0;
  }
  .philosophy__lede {
    margin: var(--space-4) 0 0;
    font-size: 17px;
    line-height: 1.55;
    color: var(--text-body);
  }
  .philosophy__stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding: var(--space-8);
    background: var(--surface);
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }

  @media (max-width: 800px) {
    .philosophy__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>

---
import Base from '@layouts/Base.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import ConsentBanner from '@components/layout/ConsentBanner.astro';
import Hero from '@components/sections/Hero.astro';
import FAQAccordion from '@components/sections/FAQAccordion.astro';
import CTABand from '@components/sections/CTABand.astro';
import { site } from '@data/site';
import { sportsOrganizationSchema, jsonLd } from '@lib/schemas';

const orgSchema = sportsOrganizationSchema();
---
<Base
  title="Frequently Asked Questions | C26 Aquatics"
  description="Answers about the C26 Aquatics competitive swim team, evaluations, meets, and logistics across the Kansas City metro — everything KC swim families ask."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(orgSchema)}></script>
  </Fragment>

  <Header />
  <main>
    <Hero
      variant="page"
      eyebrow="FAQ"
      title="Frequently asked <span class='hero-accent'>questions</span>"
      subtitle="Quick answers across team, evaluations, and logistics. Can’t find what you’re looking for? Reach out — we’re happy to help."
    />

    <FAQAccordion
      surface="faq"
      eyebrow="All questions"
      heading="Browse by topic"
      groupByCategory={true}
    />

    <CTABand
      title="Didn’t see your <span class='hero-accent accent'>question?</span>"
      subtitle="Reach out — we’re happy to help."
      primaryCta={{ label: 'Email us', href: `mailto:${site.contact.email}` }}
    />
  </main>
  <Footer />
  <ConsentBanner />
</Base>

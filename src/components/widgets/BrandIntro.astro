---
import { Image } from 'astro:assets';
import krakenWhite from '@assets/brand/kraken-white.png';
import wordmarkNavy from '@assets/brand/wordmark-navy.png';
---
<script is:inline>
  try {
    var seen = localStorage.getItem('c26:intro-seen') === '1';
    var reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!seen && !reduced) {
      document.documentElement.dataset.c26Intro = 'show';
      localStorage.setItem('c26:intro-seen', '1');
    }
  } catch (e) { /* private mode: skip */ }
</script>

<div class="c26-intro" aria-hidden="true">
  <div class="c26-intro__flash c26-intro__flash--nw"></div>
  <div class="c26-intro__flash c26-intro__flash--ne"></div>
  <div class="c26-intro__flash c26-intro__flash--sw"></div>
  <div class="c26-intro__flash c26-intro__flash--se"></div>
  <div class="c26-intro__lockup">
    <Image
      src={krakenWhite}
      alt=""
      class="c26-intro__kraken"
      width={560}
      height={560}
      densities={[1, 2]}
      loading="eager"
      decoding="sync"
    />
    <Image
      src={wordmarkNavy}
      alt=""
      class="c26-intro__wordmark"
      width={720}
      height={480}
      loading="eager"
      decoding="sync"
    />
  </div>
</div>

<script>
  const root = document.documentElement;
  if (root.dataset.c26Intro === 'show') {
    const overlay = document.querySelector<HTMLElement>('.c26-intro');
    const lockup = document.querySelector<HTMLElement>('.c26-intro__lockup');
    const headerKraken = document.querySelector<HTMLElement>('.c26-header__kraken');
    const headerWordmark = document.querySelector<HTMLElement>('.c26-header__wordmark');

    if (overlay && lockup) {
      let dismissed = false;
      const timers: number[] = [];

      const headerInitialOpacity = headerWordmark?.style.opacity ?? '';
      if (headerWordmark) headerWordmark.style.opacity = '0';

      const cleanup = () => {
        if (headerWordmark) headerWordmark.style.opacity = headerInitialOpacity;
        overlay.remove();
        delete root.dataset.c26Intro;
        window.removeEventListener('keydown', onKey);
      };

      const dismiss = () => {
        if (dismissed) return;
        dismissed = true;
        timers.forEach(clearTimeout);
        overlay.classList.add('c26-intro--dismissing');
        if (headerWordmark) {
          headerWordmark.style.transition = 'opacity 200ms ease-out';
          headerWordmark.style.opacity = '1';
        }
        window.setTimeout(cleanup, 220);
      };

      const onKey = (e: KeyboardEvent) => {
        if (e.key === 'Escape') dismiss();
      };
      overlay.addEventListener('click', dismiss);
      window.addEventListener('keydown', onKey);

      // Phase 1 + 2 start immediately via CSS animations (overlay is visible).
      // Phase 3 (fly to header) fires after the splash hold.
      timers.push(window.setTimeout(() => {
        if (dismissed) return;
        if (!headerKraken) {
          // Fallback: no header found, just fade out.
          dismiss();
          return;
        }

        const rect = headerKraken.getBoundingClientRect();
        const targetCenterX = rect.left + rect.width / 2;
        const targetCenterY = rect.top + rect.height / 2;
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        const lockupRect = lockup.getBoundingClientRect();
        const lockupSize = lockupRect.width; // square
        const scale = rect.width / lockupSize;

        overlay.style.setProperty('--c26-intro-tx', `${targetCenterX - vw / 2}px`);
        overlay.style.setProperty('--c26-intro-ty', `${targetCenterY - vh / 2}px`);
        overlay.style.setProperty('--c26-intro-scale', `${scale}`);
        overlay.classList.add('c26-intro--flying');

        if (headerWordmark) {
          headerWordmark.style.transition = 'opacity 500ms ease-out 300ms';
          headerWordmark.style.opacity = '1';
        }

        timers.push(window.setTimeout(cleanup, 850));
      }, 1400));
    }
  }
</script>

<style>
  .c26-intro {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    background: #021c36;
    overflow: hidden;
    cursor: pointer;
    transition: opacity 200ms ease-out;
  }
  :global(html[data-c26-intro='show']) .c26-intro {
    display: block;
  }
  .c26-intro--dismissing {
    opacity: 0;
    pointer-events: none;
  }

  .c26-intro__flash {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    mix-blend-mode: screen;
  }
  .c26-intro__flash--nw {
    background: radial-gradient(circle at 0% 0%, rgba(255, 255, 255, 0.7) 0%, transparent 55%);
    animation: c26-intro-flash 150ms ease-out 0ms 1 forwards;
  }
  .c26-intro__flash--ne {
    background: radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.7) 0%, transparent 55%);
    animation: c26-intro-flash 150ms ease-out 200ms 1 forwards;
  }
  .c26-intro__flash--sw {
    background: radial-gradient(circle at 0% 100%, rgba(255, 255, 255, 0.7) 0%, transparent 55%);
    animation: c26-intro-flash 150ms ease-out 400ms 1 forwards;
  }
  .c26-intro__flash--se {
    background: radial-gradient(circle at 100% 100%, rgba(255, 255, 255, 0.7) 0%, transparent 55%);
    animation: c26-intro-flash 150ms ease-out 600ms 1 forwards;
  }
  @keyframes c26-intro-flash {
    0% { opacity: 0; }
    40% { opacity: 1; }
    100% { opacity: 0; }
  }

  .c26-intro__lockup {
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(560px, 70vw);
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    transform-origin: 50% 50%;
    transition: transform 800ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .c26-intro--flying .c26-intro__lockup {
    transform:
      translate(-50%, -50%)
      translate(var(--c26-intro-tx, 0), var(--c26-intro-ty, 0))
      scale(var(--c26-intro-scale, 1));
  }

  .c26-intro__kraken {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.3;
    filter: brightness(1);
    animation: c26-intro-kraken 1400ms ease-out 0ms 1 forwards;
  }
  @keyframes c26-intro-kraken {
    0%   { opacity: 0.3; filter: brightness(1); }
    50%  { opacity: 0.5; filter: brightness(1); }
    60%  { opacity: 0.7; filter: brightness(1.4); }
    65%  { opacity: 1;   filter: brightness(1); }
    100% { opacity: 1;   filter: brightness(1); }
  }

  .c26-intro__wordmark {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 86%;
    height: auto;
    transform: translate(-50%, -50%);
    object-fit: contain;
    opacity: 0;
    animation: c26-intro-wordmark 400ms ease-out 900ms 1 forwards;
  }
  @keyframes c26-intro-wordmark {
    0%   { opacity: 0; }
    100% { opacity: 1; }
  }
  .c26-intro--flying .c26-intro__wordmark {
    transition: opacity 400ms ease-out;
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .c26-intro { display: none !important; }
  }
</style>

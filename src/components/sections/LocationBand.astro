---
/**
 * LocationBand — paper 2-column "single home" band: address + hours on the left,
 * a facility photo (placeholder for now) on the right. Distinct job from
 * ServiceAreaBand, which lists KC-metro cities as crawlable text for local SEO.
 *
 * Address/venue/amenities come from `site.address` + `site.place`. Hours render
 * only once `site.place.hours` is filled in (still TODO — confirm with client).
 */
import { Image } from 'astro:assets';
import krakenNavy from '@assets/brand/kraken-navy.png';
import { site } from '@data/site';

interface Props {
  eyebrow?: string;
  heading?: string;
  blurb?: string;
  address?: string;
  hours?: string;
  /** Runtime path (under /public) to a facility / exterior photo. */
  image?: string;
  imageAlt?: string;
}

const a = site.address;
const { venue, amenities, mapsUrl, hours: siteHours } = site.place;
// Display form: break the suite onto its own clause for readability; the raw
// `streetAddress` (with "Suite") stays intact for JSON-LD.
const streetDisplay = a.streetAddress.replace(/ (Suite|Ste\.?) /i, ', $1 ');
const composedAddress = `${streetDisplay}, ${a.addressLocality}, ${a.addressRegion} ${a.postalCode}`;

const {
  eyebrow = 'Our home',
  heading = 'One pool. One standard.',
  blurb = `Everything happens under one roof — inside ${venue} in Overland Park. No satellites, no rotating rental lanes. Every swimmer trains in the same water with the same staff.`,
  address = composedAddress,
  hours = siteHours,
  image,
  imageAlt = `The C26 Aquatics facility inside ${venue}`,
} = Astro.props;
---
<section class="location" aria-labelledby="location-title">
  <div class="container location__inner">
    <div class="location__copy">
      <p class="location__eyebrow">{eyebrow}</p>
      <h2 id="location-title" class="location__heading">{heading}</h2>
      <p class="location__blurb">{blurb}</p>

      <dl class="location__facts">
        <div class="location__fact">
          <dt>Inside</dt>
          <dd>{venue}</dd>
        </div>
        <div class="location__fact">
          <dt>Address</dt>
          <dd>{address}</dd>
        </div>
        {hours && (
          <div class="location__fact">
            <dt>Hours</dt>
            <dd>{hours}</dd>
          </div>
        )}
      </dl>

      {amenities.length > 0 && (
        <ul class="location__amenities" aria-label="Facility amenities">
          {amenities.map((item) => (
            <li class="location__amenity">{item}</li>
          ))}
        </ul>
      )}

      <a class="location__directions" href={mapsUrl} target="_blank" rel="noopener noreferrer">
        Get directions
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>

    <div class="location__media">
      {image ? (
        <img
          class="location__photo"
          src={image}
          alt={imageAlt}
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="location__placeholder" role="img" aria-label="Facility map / exterior photo — coming soon">
          <Image
            src={krakenNavy}
            alt=""
            class="location__placeholder-kraken"
            widths={[320, 480]}
            sizes="(max-width: 800px) 60vw, 40vw"
            loading="lazy"
          />
          <span class="location__placeholder-label">Facility map / exterior</span>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .location {
    background: var(--surface-alt);
    padding: var(--section-y) 0;
  }
  .location__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(32px, 6vw, 80px);
  }

  .location__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-600);
    margin: 0 0 var(--space-2);
  }
  .location__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(30px, 4vw, 44px);
    line-height: 1.02;
    letter-spacing: var(--ls-tight);
    color: var(--navy-700);
    margin: 0 0 var(--space-4);
  }
  .location__blurb {
    font-size: 17px;
    line-height: 1.6;
    color: var(--text-body);
    margin: 0 0 var(--space-6);
    max-width: 52ch;
  }

  .location__facts {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .location__fact {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: var(--space-4);
    align-items: baseline;
    padding-top: var(--space-3);
    border-top: 1px solid var(--border);
  }
  .location__fact dt {
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 12px;
    color: var(--teal-700);
  }
  .location__fact dd {
    margin: 0;
    font-size: 16px;
    line-height: 1.5;
    color: var(--text-strong);
  }

  .location__amenities {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .location__amenity {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 12px;
    color: var(--teal-700);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    padding: 4px 12px;
  }

  .location__directions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-6);
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 14px;
    color: var(--teal-700);
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition:
      border-color var(--dur-base) var(--ease-out),
      color var(--dur-base) var(--ease-out);
  }
  .location__directions:hover {
    color: var(--navy-700);
    border-bottom-color: var(--teal-500);
  }

  .location__media {
    aspect-ratio: 4 / 3;
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .location__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .location__placeholder {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--mist) 0%, var(--surface-inset) 100%);
    overflow: hidden;
  }
  .location__placeholder-kraken {
    width: 46%;
    height: auto;
    opacity: 0.12;
  }
  .location__placeholder-label {
    position: absolute;
    bottom: var(--space-4);
    left: 0;
    right: 0;
    text-align: center;
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 12px;
    color: var(--text-muted);
  }

  @media (max-width: 800px) {
    .location__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>

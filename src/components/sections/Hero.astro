---
/**
 * Hero section.
 *
 * `variant="home"` — full-bleed navy hero with kraken watermark on the right,
 *   large condensed-uppercase H1, dual CTAs.
 * `variant="page"` — short paper-to-mist band, navy H1, optional single CTA.
 *
 * `title` is rendered with `set:html` so callers can embed accent spans, e.g.
 *   title="Become a <span class=\"hero-accent\">stronger</span> swimmer"
 * (a built-in `.hero-accent` rule colors that span var(--orange-500); callers
 * can also pass any inline style — the prop is HTML.)
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Button from '@components/ui/Button.astro';
import krakenWhite from '@assets/brand/kraken-white.png';

interface CTA {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  variant: 'home' | 'page';
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: CTA;
  secondaryCta?: CTA;
  image?: ImageMetadata;
}

const {
  variant,
  eyebrow,
  title,
  subtitle,
  primaryCta,
  secondaryCta,
  image,
} = Astro.props;
---
{variant === 'home' ? (
  <section class="hero hero--home" aria-labelledby="hero-title">
    <Image
      src={krakenWhite}
      alt=""
      class="hero__watermark"
      widths={[480, 720, 960]}
      sizes="(min-width: 1024px) 560px, 60vw"
      loading="eager"
    />
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="container hero__inner">
      <div class="hero__copy">
        {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
        <h1 id="hero-title" class="hero__title" set:html={title}></h1>
        {subtitle && <p class="hero__subtitle">{subtitle}</p>}
        {(primaryCta || secondaryCta) && (
          <div class="hero__ctas">
            {primaryCta && (
              <Button
                href={primaryCta.href}
                external={primaryCta.external}
                variant="primary"
                size="lg"
              >
                {primaryCta.label}
              </Button>
            )}
            {secondaryCta && (
              <Button
                href={secondaryCta.href}
                variant="outline-light"
                size="lg"
              >
                {secondaryCta.label}
              </Button>
            )}
          </div>
        )}
      </div>
    </div>
  </section>
) : (
  <section class="hero hero--page" aria-labelledby="hero-title">
    <div class="container hero__inner">
      <div class="hero__copy">
        {eyebrow && <p class="hero__eyebrow hero__eyebrow--page">{eyebrow}</p>}
        <h1 id="hero-title" class="hero__title hero__title--page" set:html={title}></h1>
        {subtitle && <p class="hero__subtitle hero__subtitle--page">{subtitle}</p>}
        {(primaryCta || secondaryCta) && (
          <div class="hero__ctas">
            {primaryCta && (
              <Button
                href={primaryCta.href}
                external={primaryCta.external}
                variant="primary"
                size="lg"
              >
                {primaryCta.label}
              </Button>
            )}
            {secondaryCta && (
              <Button href={secondaryCta.href} variant="outline" size="lg">
                {secondaryCta.label}
              </Button>
            )}
          </div>
        )}
      </div>
      {image && (
        <div class="hero__image-wrap">
          <Image
            src={image}
            alt=""
            class="hero__image"
            widths={[480, 720, 960]}
            sizes="(min-width: 900px) 440px, 90vw"
          />
        </div>
      )}
    </div>
  </section>
)}

<style>
  .hero {
    position: relative;
    overflow: hidden;
  }

  /* ----- home variant ----- */
  .hero--home {
    background:
      linear-gradient(180deg, var(--navy-800) 0%, var(--navy-900) 100%),
      var(--navy-800);
    min-height: 560px;
    display: flex;
    align-items: flex-end;
    color: var(--text-on-dark);
    padding: 0;
  }
  .hero--home .hero__inner {
    position: relative;
    padding: var(--space-16) 0 var(--space-20);
    width: 100%;
  }
  .hero--home .hero__copy {
    max-width: 720px;
    position: relative;
    z-index: 2;
  }
  .hero__watermark {
    position: absolute;
    right: -60px;
    top: 50%;
    transform: translateY(-50%);
    width: clamp(360px, 50vw, 560px);
    height: auto;
    object-fit: contain;
    opacity: 0.08;
    pointer-events: none;
    z-index: 0;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(11, 31, 43, 0.15) 0%,
      rgba(11, 31, 43, 0.55) 60%,
      rgba(11, 31, 43, 0.88) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .hero__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-400);
    margin: 0 0 var(--space-3);
  }

  .hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    text-transform: uppercase;
    font-size: clamp(52px, 8vw, 92px);
    line-height: 0.9;
    letter-spacing: var(--ls-tight);
    color: var(--white);
    margin: 0;
  }
  .hero__title :global(.hero-accent),
  .hero__title :global(.accent) {
    color: var(--orange-500);
  }

  .hero__subtitle {
    font-size: 19px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.85);
    max-width: 520px;
    margin: var(--space-5) 0 var(--space-8);
  }

  .hero__ctas {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ----- page variant ----- */
  .hero--page {
    background: linear-gradient(180deg, var(--paper) 0%, var(--mist) 100%);
    padding: var(--space-16) 0;
    color: var(--text-body);
  }
  .hero--page .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: var(--space-12);
    align-items: center;
  }
  .hero--page .hero__copy {
    max-width: 640px;
  }
  .hero__eyebrow--page { color: var(--teal-600); }
  .hero__title--page {
    color: var(--navy-700);
    font-size: clamp(40px, 6vw, 72px);
    line-height: 0.92;
  }
  .hero__subtitle--page {
    color: var(--text-body);
    margin: var(--space-5) 0 var(--space-8);
    font-size: 19px;
    line-height: 1.5;
    max-width: 440px;
  }
  .hero__image-wrap {
    width: 100%;
    height: 360px;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--mist);
  }
  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 800px) {
    .hero--page .hero__inner {
      grid-template-columns: 1fr;
    }
    .hero__image-wrap { display: none; }
    .hero--home { min-height: 460px; }
  }
</style>

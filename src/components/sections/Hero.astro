---
/**
 * Hero section.
 *
 * `variant="home"` — full-bleed navy hero with kraken watermark on the right,
 *   large condensed-uppercase H1, dual CTAs.
 * `variant="page"` — short paper-to-mist band, navy H1, optional single CTA.
 *
 * `title` is rendered with `set:html` so callers can embed accent spans, e.g.
 *   title="Become a <span class=\"hero-accent\">stronger</span> swimmer"
 * (a built-in `.hero-accent` rule colors that span var(--orange-500); callers
 * can also pass any inline style — the prop is HTML.)
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Button from '@components/ui/Button.astro';
import homeHeroBg from '@assets/hero/hero-1.png';
import wordmarkLight from '@assets/brand/wordmark-light-transparent.png';
import krakenWhite from '@assets/brand/kraken-white.png';

interface CTA {
  label: string;
  href: string;
  external?: boolean;
}

interface Props {
  variant: 'home' | 'page';
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: CTA;
  secondaryCta?: CTA;
  image?: ImageMetadata;
}

const {
  variant,
  eyebrow,
  title,
  subtitle,
  primaryCta,
  secondaryCta,
  image,
} = Astro.props;
---
{variant === 'home' ? (
  <section class="hero hero--home" aria-labelledby="hero-title">
    <Image
      src={homeHeroBg}
      alt=""
      class="hero__bg"
      widths={[800, 1200, 1600, 2000]}
      sizes="100vw"
      loading="eager"
      decoding="sync"
    />
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="container hero__inner">
      <div class="hero__brand">
        <span class="hero__lockup">
          <Image
            src={krakenWhite}
            alt=""
            class="hero__lockup-kraken"
            widths={[400, 560, 720]}
            sizes="(min-width: 800px) 620px, 88vw"
            loading="eager"
            decoding="sync"
          />
          <Image
            src={wordmarkLight}
            alt="C26 Aquatics"
            class="hero__lockup-wordmark"
            widths={[400, 560, 720]}
            sizes="(min-width: 800px) 560px, 80vw"
            loading="eager"
            decoding="sync"
          />
        </span>
      </div>
      <div class="hero__copy">
        {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
        <h1 id="hero-title" class="hero__title hero__title--home" set:html={title}></h1>
        {subtitle && <p class="hero__subtitle">{subtitle}</p>}
        {(primaryCta || secondaryCta) && (
          <div class="hero__ctas">
            {primaryCta && (
              <Button
                href={primaryCta.href}
                external={primaryCta.external}
                variant="primary"
                size="lg"
              >
                {primaryCta.label}
              </Button>
            )}
            {secondaryCta && (
              <Button
                href={secondaryCta.href}
                variant="outline-magenta"
                size="lg"
              >
                {secondaryCta.label}
              </Button>
            )}
          </div>
        )}
      </div>
    </div>
  </section>
) : (
  <section class="hero hero--page" aria-labelledby="hero-title">
    <div class="container hero__inner">
      <div class="hero__copy">
        {eyebrow && <p class="hero__eyebrow hero__eyebrow--page">{eyebrow}</p>}
        <h1 id="hero-title" class="hero__title hero__title--page" set:html={title}></h1>
        {subtitle && <p class="hero__subtitle hero__subtitle--page">{subtitle}</p>}
        {(primaryCta || secondaryCta) && (
          <div class="hero__ctas">
            {primaryCta && (
              <Button
                href={primaryCta.href}
                external={primaryCta.external}
                variant="primary"
                size="lg"
              >
                {primaryCta.label}
              </Button>
            )}
            {secondaryCta && (
              <Button href={secondaryCta.href} variant="outline" size="lg">
                {secondaryCta.label}
              </Button>
            )}
          </div>
        )}
      </div>
      {image && (
        <div class="hero__image-wrap">
          <Image
            src={image}
            alt=""
            class="hero__image"
            widths={[480, 720, 960]}
            sizes="(min-width: 900px) 440px, 90vw"
          />
        </div>
      )}
    </div>
  </section>
)}

<style>
  .hero {
    position: relative;
    overflow: hidden;
  }

  /* ----- home variant ----- */
  .hero--home {
    background: var(--navy-wordmark);
    min-height: 560px;
    display: flex;
    align-items: flex-end;
    color: var(--text-on-dark);
    padding: 0;
  }
  .hero--home .hero__inner {
    position: relative;
    padding: var(--space-16) 0;
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-12);
    align-items: center;
  }
  .hero--home .hero__brand {
    position: relative;
    z-index: 3;
    display: flex;
    justify-content: center;
  }
  .hero--home .hero__copy {
    position: relative;
    z-index: 3;
    max-width: 560px;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center -20px;
    z-index: 0;
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__bg { will-change: auto; }
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        rgba(14, 19, 48, 0.3) 0%,
        rgba(14, 19, 48, 0.55) 45%,
        rgba(14, 19, 48, 0.86) 100%
      ),
      linear-gradient(
        180deg,
        rgba(14, 19, 48, 0.2) 0%,
        rgba(14, 19, 48, 0.55) 100%
      );
    z-index: 1;
    pointer-events: none;
  }

  .hero__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-400);
    margin: 0 0 var(--space-3);
  }

  .hero__title {
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    text-transform: uppercase;
    font-size: clamp(52px, 8vw, 92px);
    line-height: 0.9;
    letter-spacing: var(--ls-tight);
    color: var(--white);
    margin: 0;
  }
  .hero__title :global(.hero-accent),
  .hero__title :global(.accent) {
    color: var(--orange-500);
  }
  .hero__title :global(.hero-accent-magenta) {
    color: var(--magenta-400);
  }
  .hero__title--home {
    font-size: clamp(40px, 5vw, 76px);
    line-height: 0.95;
  }
  .hero__title--wordmark {
    display: block;
    line-height: 1;
    margin: 0;
  }
  /* Stacked logo lockup: kraken on top (top ~2/3 solid, bottom 1/3 fades to
     transparent via mask), wordmark sits below pulled up into the fade zone. */
  .hero__lockup {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: clamp(280px, 56vw, 560px);
  }
  .hero__lockup-kraken {
    display: block;
    width: 108%;
    height: auto;
    margin-bottom: -55%;
    -webkit-mask-image: linear-gradient(to bottom, black 0%, black 52%, transparent 92%);
            mask-image: linear-gradient(to bottom, black 0%, black 52%, transparent 92%);
    filter: drop-shadow(0 6px 32px rgba(0, 0, 0, 0.4));
    pointer-events: none;
  }
  .hero__lockup-wordmark {
    position: relative;
    z-index: 2;
    display: block;
    width: 100%;
    height: auto;
    filter: drop-shadow(0 4px 18px rgba(0, 0, 0, 0.45));
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__lockup-wordmark { will-change: auto; }
  }

  .hero__subtitle {
    font-size: 19px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.85);
    max-width: 520px;
    margin: var(--space-5) 0 var(--space-8);
  }

  .hero__ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* ----- page variant ----- */
  .hero--page {
    background: linear-gradient(180deg, var(--paper) 0%, var(--mist) 100%);
    padding: var(--space-16) 0;
    color: var(--text-body);
  }
  .hero--page .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: var(--space-12);
    align-items: center;
  }
  .hero--page .hero__copy {
    max-width: 640px;
  }
  .hero__eyebrow--page { color: var(--teal-600); }
  .hero__title--page {
    color: var(--navy-700);
    font-size: clamp(40px, 6vw, 72px);
    line-height: 0.92;
  }
  .hero__subtitle--page {
    color: var(--text-body);
    margin: var(--space-5) 0 var(--space-8);
    font-size: 19px;
    line-height: 1.5;
    max-width: 440px;
  }
  .hero__image-wrap {
    width: 100%;
    height: 360px;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--mist);
  }
  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 800px) {
    .hero--page .hero__inner {
      grid-template-columns: 1fr;
    }
    .hero__image-wrap { display: none; }
    .hero--home { min-height: 460px; }
    .hero--home .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .hero--home .hero__brand { justify-content: flex-start; }
  }
</style>

<script>
  // Parallax: photo drifts at 0.4x scroll (slow-zooms up to 1.12); wordmark
  // drifts upward at 0.18x scroll (foreground layer, moves faster than the
  // page — feels like it's rising into the header as you scroll).
  const heroBg = document.querySelector<HTMLElement>('.hero--home .hero__bg');
  const heroWordmark = document.querySelector<HTMLElement>('.hero--home .hero__lockup-wordmark');
  if ((heroBg || heroWordmark) && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let y = 0;
    let ticking = false;
    const update = () => {
      if (heroBg) {
        const scale = Math.min(1 + y * 0.0002, 1.12);
        heroBg.style.transform = `translate3d(0, ${y * 0.4}px, 0) scale(${scale})`;
      }
      if (heroWordmark) {
        heroWordmark.style.transform = `translate3d(0, ${-y * 0.18}px, 0)`;
      }
      ticking = false;
    };
    window.addEventListener(
      'scroll',
      () => {
        y = window.scrollY;
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );
  }
</script>

---
/**
 * DifferenceMatrix — the "Traditional Swim Clubs vs C26 Aquatics" comparison,
 * rendered as a head-to-head pair of cards: a muted "Traditional" card (✕
 * badges) beside a navy C26 card with a teal radial glow (✓ badges). Stacks to
 * one column under ~720px. Data from src/data/approach.ts.
 */
import {
  differenceIntro,
  differenceRows,
  condensedDifferenceRows,
  differenceSummary,
  type DifferenceRow,
} from '@data/approach';

interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  rows?: DifferenceRow[];
  summary?: string;
  tagline?: string;
  /** Homepage teaser: 4 rows, no intro/summary prose, optional CTA link. */
  condensed?: boolean;
  cta?: { label: string; href: string };
  /** Anchor id + deep-link target. Defaults to "difference". */
  id?: string;
}

const {
  eyebrow = 'Why C26',
  heading = 'The C26 difference',
  intro,
  rows,
  summary = differenceSummary,
  tagline = 'One Home. One Pool. One Standard.',
  condensed = false,
  cta,
  id = 'difference',
} = Astro.props;

const displayRows = rows ?? (condensed ? condensedDifferenceRows : differenceRows);
const introText = intro ?? (condensed ? undefined : differenceIntro);
---
<section id={id} class:list={['diffmatrix', { 'diffmatrix--condensed': condensed }]} aria-labelledby="diffmatrix-title">
  <div class="container">
    <p class="diffmatrix__eyebrow">{eyebrow}</p>
    <h2 id="diffmatrix-title" class="diffmatrix__heading">{heading}</h2>
    {introText && <p class="diffmatrix__intro">{introText}</p>}

    <div class="h2h">
      <!-- Traditional swim clubs -->
      <div class="h2h__card h2h__card--trad">
        <p class="h2h__label h2h__label--trad">Traditional Swim Clubs</p>
        <ul class="h2h__list" aria-label="How traditional swim clubs operate">
          {displayRows.map((r) => (
            <li class="h2h__item">
              <span class="h2h__badge h2h__badge--x" aria-hidden="true">✕</span>
              <span class="h2h__text h2h__text--trad">{r.traditional}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- C26 Aquatics -->
      <div class="h2h__card h2h__card--c26">
        <span class="h2h__glow" aria-hidden="true"></span>
        <p class="h2h__label h2h__label--c26">C26 Aquatics</p>
        <ul class="h2h__list" aria-label="How C26 Aquatics operates">
          {displayRows.map((r) => (
            <li class="h2h__item">
              <span class="h2h__badge h2h__badge--check" aria-hidden="true">✓</span>
              <span class="h2h__text h2h__text--c26">{r.c26}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="dm__summary">
      {!condensed && <p class="dm__summary-text">{summary}</p>}
      <p class="dm__tagline">{tagline}</p>
      {cta && (
        <a href={cta.href} class="dm__cta">
          {cta.label}
          <span aria-hidden="true">&rarr;</span>
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .diffmatrix {
    background: var(--surface);
    padding: var(--section-y) 0;
    scroll-margin-top: 96px;
  }
  .diffmatrix__eyebrow {
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: var(--fs-eyebrow);
    color: var(--teal-600);
    margin: 0;
  }
  .diffmatrix__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: clamp(30px, 4vw, 44px);
    line-height: 1.02;
    letter-spacing: var(--ls-tight);
    color: var(--navy-700);
    margin: var(--space-2) 0 0;
  }
  .diffmatrix__intro {
    font-size: 18px;
    line-height: 1.55;
    color: var(--text-body);
    margin: 14px 0 0;
    max-width: 680px;
  }

  /* Head-to-head cards */
  .h2h {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    align-items: stretch;
    margin-top: 36px;
  }
  .h2h__card {
    border-radius: var(--r-lg);
    padding: 26px 26px 30px;
  }
  .h2h__card--trad {
    background: var(--surface-alt);
    border: 1px solid var(--border);
  }
  .h2h__card--c26 {
    background: var(--navy-700);
    position: relative;
    overflow: hidden;
  }
  .h2h__glow {
    position: absolute;
    top: 0;
    right: 0;
    width: 120px;
    height: 120px;
    background: radial-gradient(
      circle at top right,
      color-mix(in srgb, var(--teal-400) 30%, transparent),
      transparent 70%
    );
    pointer-events: none;
  }

  .h2h__label {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 17px;
    margin: 0 0 18px;
    position: relative;
  }
  .h2h__label--trad {
    color: var(--text-muted);
  }
  .h2h__label--c26 {
    color: var(--teal-400);
  }

  .h2h__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 15px;
    position: relative;
  }
  .h2h__item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .h2h__badge {
    flex: none;
    width: 20px;
    height: 20px;
    border-radius: var(--r-pill);
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    font-weight: var(--fw-black);
  }
  .h2h__badge--x {
    background: var(--border);
    color: var(--text-muted);
    font-size: 13px;
  }
  .h2h__badge--check {
    background: var(--teal-400);
    color: var(--navy-900);
    font-size: 12px;
  }
  .h2h__text {
    font-size: 15px;
    line-height: 1.5;
  }
  .h2h__text--trad {
    color: var(--text-muted);
  }
  .h2h__text--c26 {
    color: var(--text-on-dark);
  }

  /* Summary + tagline */
  .dm__summary {
    margin-top: var(--space-8);
    max-width: 760px;
  }
  .dm__summary-text {
    font-size: 17px;
    line-height: 1.6;
    color: var(--text-body);
    margin: 0;
  }
  .dm__tagline {
    font-family: var(--font-display);
    font-weight: var(--fw-black);
    text-transform: uppercase;
    letter-spacing: var(--ls-tight);
    font-size: clamp(20px, 3vw, 28px);
    color: var(--navy-700);
    margin: var(--space-5) 0 0;
  }
  .dm__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-5);
    font-family: var(--font-subhead);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 14px;
    color: var(--teal-700);
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition:
      color var(--dur-base) var(--ease-out),
      border-color var(--dur-base) var(--ease-out);
  }
  .dm__cta:hover {
    color: var(--navy-700);
    border-bottom-color: var(--teal-500);
  }

  @media (max-width: 720px) {
    .h2h {
      grid-template-columns: 1fr;
    }
  }
</style>

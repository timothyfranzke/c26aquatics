---
/**
 * Content card. Slot for content; padding + tone props control density and theme.
 */
interface Props {
  as?: 'div' | 'article' | 'section';
  padding?: 'sm' | 'md' | 'lg';
  tone?: 'surface' | 'inset' | 'dark';
  interactive?: boolean;
  class?: string;
}

const {
  as: Tag = 'div',
  padding = 'md',
  tone = 'surface',
  interactive = false,
  class: className,
} = Astro.props;

const classList = [
  'c26-card',
  `c26-card--${tone}`,
  `c26-card--p-${padding}`,
  interactive ? 'c26-card--interactive' : '',
  className ?? '',
]
  .filter(Boolean)
  .join(' ');
---
<Tag class={classList}>
  <slot />
</Tag>

<style>
  .c26-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    border-radius: var(--r-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--dur-base) var(--ease-out),
      box-shadow var(--dur-base) var(--ease-out);
  }

  .c26-card--surface {
    background: var(--surface);
    color: var(--text-body);
  }
  .c26-card--inset {
    background: var(--surface-inset);
    color: var(--text-body);
  }
  .c26-card--dark {
    background: var(--surface-dark);
    color: var(--text-on-dark);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .c26-card--p-sm { padding: var(--space-4); }
  .c26-card--p-md { padding: var(--space-6); }
  .c26-card--p-lg { padding: var(--space-8); }

  .c26-card--interactive { cursor: pointer; }
  .c26-card--interactive:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }
</style>

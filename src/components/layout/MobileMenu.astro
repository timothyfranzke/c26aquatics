---
import { primaryNav } from '@data/nav';
import { site } from '@data/site';
import Button from '@components/ui/Button.astro';

const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
function isCurrent(href: string): boolean {
  const target = href.replace(/\/+$/, '') || '/';
  return target === currentPath;
}
---
<div
  id="c26-mobile-menu"
  class="c26-mm"
  data-open="false"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
>
  <button
    type="button"
    class="c26-mm__backdrop"
    aria-label="Close menu"
    data-mobile-menu-close
    tabindex="-1"
  ></button>

  <div class="c26-mm__panel" role="document">
    <div class="c26-mm__head">
      <span class="c26-mm__title">Menu</span>
      <button
        type="button"
        class="c26-mm__close"
        aria-label="Close menu"
        data-mobile-menu-close
      >
        <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true" focusable="false">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
        </svg>
      </button>
    </div>

    <nav aria-label="Mobile">
      <ul class="c26-mm__list">
        {primaryNav.map((item) => (
          <li>
            <a
              href={item.href}
              class="c26-mm__link"
              aria-current={isCurrent(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="c26-mm__cta">
      <Button href={site.booking.lessons} variant="primary" size="lg" full external>
        Book Now
      </Button>
    </div>
  </div>
</div>

<script>
  const menu = document.getElementById('c26-mobile-menu');
  const toggles = document.querySelectorAll<HTMLElement>('[data-mobile-menu-toggle]');
  const closers = document.querySelectorAll<HTMLElement>('[data-mobile-menu-close]');
  const links = menu?.querySelectorAll<HTMLAnchorElement>('a.c26-mm__link');

  const setOpen = (open: boolean) => {
    if (!menu) return;
    menu.dataset.open = open ? 'true' : 'false';
    menu.setAttribute('aria-hidden', open ? 'false' : 'true');
    document.body.dataset.menuOpen = open ? 'true' : 'false';
    document.body.style.overflow = open ? 'hidden' : '';
    toggles.forEach((t) => t.setAttribute('aria-expanded', open ? 'true' : 'false'));
  };

  toggles.forEach((t) => {
    t.addEventListener('click', () => {
      const isOpen = menu?.dataset.open === 'true';
      setOpen(!isOpen);
    });
  });
  closers.forEach((c) => c.addEventListener('click', () => setOpen(false)));
  links?.forEach((l) => l.addEventListener('click', () => setOpen(false)));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.dataset.open === 'true') setOpen(false);
  });
</script>

<style>
  .c26-mm {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
    visibility: hidden;
    transition: visibility 0s linear var(--dur-base);
  }
  .c26-mm[data-open='true'] {
    pointer-events: auto;
    visibility: visible;
    transition: visibility 0s;
  }

  .c26-mm__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(11, 31, 43, 0.6);
    opacity: 0;
    transition: opacity var(--dur-base) var(--ease-out);
    border: 0;
    padding: 0;
    cursor: pointer;
  }
  .c26-mm[data-open='true'] .c26-mm__backdrop {
    opacity: 1;
  }

  .c26-mm__panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: min(360px, 90vw);
    background: var(--navy-700);
    color: var(--text-on-dark);
    box-shadow: var(--shadow-lg);
    transform: translateX(100%);
    transition: transform var(--dur-base) var(--ease-out);
    display: flex;
    flex-direction: column;
    padding: var(--space-6);
    gap: var(--space-6);
    overflow-y: auto;
  }
  .c26-mm[data-open='true'] .c26-mm__panel {
    transform: translateX(0);
  }

  .c26-mm__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .c26-mm__title {
    font-family: var(--font-subhead);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-eyebrow);
    font-size: 12px;
    color: var(--text-on-dark-muted);
  }
  .c26-mm__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: transparent;
    color: var(--text-on-dark);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--r-xs);
  }
  .c26-mm__close:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .c26-mm__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .c26-mm__link {
    display: block;
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 22px;
    color: var(--text-on-dark);
    padding: 12px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .c26-mm__link[aria-current='page'] {
    color: var(--orange-500);
  }
  .c26-mm__link:hover {
    color: var(--teal-400);
  }

  .c26-mm__cta {
    margin-top: auto;
  }
</style>
